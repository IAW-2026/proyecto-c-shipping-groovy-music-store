// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
// EMPRESA
// Una empresa gestiona envíos y emplea usuarios
model Empresa {
  id      Int      @id @default(autoincrement())
  nombre  String

  envios   Envio[]    @relation("EmpresaGestiona")
  usuarios Usuario[]  @relation("EmpresaEmplea")
}

// USUARIO
// Empleado de la empresa que opera los envíos
model Usuario {
  id_clerk String  @id
  mail     String

  empresaId Int
  empresa   Empresa @relation("EmpresaEmplea", fields: [empresaId], references: [id])
}

// DIRECCION
// Dirección de entrega del envío
model Direccion {
  id         Int    @id @default(autoincrement())
  calle      String
  ciudad     String
  provincia  String
  cod_postal String
  pais       String

  envios Envio[]
}

// ENVIO
// Entidad central del sistema
model Envio {
  id           Int    @id @default(autoincrement())
  order_id     String
  seller_id    Int
  buyer_id     Int
  direccion_id Int
  estado       String

  empresaId Int
  empresa   Empresa   @relation("EmpresaGestiona", fields: [empresaId], references: [id])

  direccion Direccion @relation(fields: [direccion_id], references: [id])

  eventos EventoDeEnvio[]
}

// EVENTO_DE_ENVIO
// Historial de eventos asociados a un envío
model EventoDeEnvio {
  id          Int      @id @default(autoincrement())
  envio_id    Int
  descripcion String
  timestamp   DateTime @default(now())

  envio Envio @relation(fields: [envio_id], references: [id])
}