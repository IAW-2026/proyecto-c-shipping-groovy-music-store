generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Empresa {
  id      String   @id @default(uuid()) 
  nombre  String

  envios   Envio[]    @relation("EmpresaGestiona")
  usuarios Usuario[]  @relation("EmpresaEmplea")
}

model Usuario {
  id_clerk  String  @id
  mail      String
  role      String  @default("OPERADOR")
  empresaId String  
  empresa   Empresa @relation("EmpresaEmplea", fields: [empresaId], references: [id])
}

model Direccion {
  id         String @id @default(uuid()) 
  calle      String
  ciudad     String
  provincia  String
  cod_postal String
  pais       String

  envios Envio[]
}

model Envio {
  id           String @id @default(uuid()) 
  order_id     String @unique
  seller_id    String
  buyer_id     String
  direccion_id String 
  estado       String

  empresaId String   
  empresa   Empresa   @relation("EmpresaGestiona", fields: [empresaId], references: [id])
  direccion Direccion @relation(fields: [direccion_id], references: [id])

  eventos EventoDeEnvio[]
}

model EventoDeEnvio {
  id          String   @id @default(uuid())  
  envio_id    String   
  descripcion String
  timestamp   DateTime @default(now())

  envio Envio @relation(fields: [envio_id], references: [id])
}